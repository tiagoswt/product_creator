# =============================================================================
# Streamlit Secrets - PostgreSQL / Supabase Connection
# =============================================================================
# Copy this file to secrets.toml (same directory) and fill in your values.
# Never commit secrets.toml to version control.

[connections.postgresql]
dialect = "postgresql"
host = "aws-0-eu-west-3.pooler.supabase.com"
port = 6543
database = "postgres"
username = "your_db_username"
password = "your_db_password"

# Optional: direct connection (bypasses pooler, use for migrations)
# host = "db.<your-project-ref>.supabase.co"
# port = 5432
