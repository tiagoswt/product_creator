# =============================================================================
# SweetCare AI Product Content Creator - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# --- Required ---

# OpenAI API key (required for LLM extraction and evaluation)
OPENAI_API_KEY=sk-...

# --- Optional but Recommended ---

# Groq API key (alternative/additional LLM provider)
GROQ_API_KEY=gsk_...

# LangSmith tracing (for monitoring LLM calls)
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai_product_creator

# Firecrawl API key (for enhanced website scraping)
FIRECRAWL_API_KEY=fc-...

# Dropbox (for automatic cloud backup of extraction results)
DROPBOX_ACCESS_TOKEN=sl....

# --- Authentication ---

# Master password used for the admin account bootstrap
MASTER_PASSWORD=your_secure_password

# Legacy simple auth (if not using PostgreSQL auth)
AUTH_PASSWORD=your_password
AUTH_USERNAME=admin
